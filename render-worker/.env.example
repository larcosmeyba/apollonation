# ── Worker auth (shared secret; MUST match the Supabase secret of the same name) ──
RENDER_WORKER_SECRET=generate-a-long-random-string

# ── Cloudflare R2 (S3-compatible temp storage; bucket needs a 1-day lifecycle rule) ──
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_BUCKET=apollo-renders
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# ── Optional render tuning ──
# DOWNLOAD_URL_TTL_SECONDS=86400   # presigned URL lifetime (default 24h)
# RENDER_WIDTH=1920
# RENDER_HEIGHT=1080
# RENDER_FPS=30
# FFMPEG_PRESET=veryfast
# FFMPEG_CRF=20
# PORT=8080                        # Railway sets this automatically
